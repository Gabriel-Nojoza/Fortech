NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key


# Public base URL of the deployed app, used in callbacks/webhooks.
NEXT_PUBLIC_APP_URL=https://fortechoficial.com.br

# Secret shared with the platform scheduler or n8n flow that calls /api/schedules/due/all
# Without this, the endpoint returns 503 "Endpoint nao configurado".
PLATFORM_SCHEDULER_SECRET=troque-por-um-segredo-forte-e-unico

# Optional fallbacks for status/configuration badges.
PBI_CLIENT_ID=831263d9-e6be-46fd-86cb-801969185def
N8N_WEBHOOK_URL=

# Configure o callback_secret por empresa em Configuracoes > N8N para o fluxo de WhatsApp funcionar.

# Optional platform admin email override.a
PLATFORM_ADMIN_EMAIL=admin@seuapp.com

# Optional external bot service URL when the bot is not running on the same host.
WHATSAPP_BOT_SERVICE_URL=http://127.0.0.1:3010

# Optional absolute path to Chrome/Edge used to render Power BI HTML into PDF.
REPORT_PDF_BROWSER_PATH=

# Optional Power BI PDF fallback capture quality.
# Increase gradually only if needed. Values too high can make Chrome/Edge headless close during capture.
REPORT_PDF_CAPTURE_WIDTH=2560
REPORT_PDF_CAPTURE_HEIGHT=1707
REPORT_PDF_DEVICE_SCALE_FACTOR=3
REPORT_PDF_SCREENSHOT_SCALE=3.5

# WhatsApp bot service settings.
BOT_PORT=3010
BOT_PDF_BASE_DIR=

# Google Places API (New) key, usado pela prospeccao de leads (/admin/leads).
# NUNCA prefixar com NEXT_PUBLIC_ - essa chave so pode ser usada no servidor.
GOOGLE_MAPS_API_KEY=
